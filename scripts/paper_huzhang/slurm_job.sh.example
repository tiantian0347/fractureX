#!/bin/bash
#SBATCH --job-name=fx-paper-hz
#SBATCH --array=0-2
#SBATCH --cpus-per-task=8
#SBATCH --time=48:00:00
#SBATCH --output=results/logs/slurm_%x_%A_%a.out
#SBATCH --error=results/logs/slurm_%x_%A_%a.err

set -euo pipefail
cd "${SLURM_SUBMIT_DIR:-.}"

export FRACTUREX_ENV_QUIET=1

# model0, model1 (square), model2
CASES=(model0 model1 model2)
CASE="${CASES[$SLURM_ARRAY_TASK_ID]}"

mkdir -p results/logs

bash scripts/paper_huzhang/run_background_job.sh "${CASE}"

# On the last array task, wait for siblings then collect (optional).
if [[ "${SLURM_ARRAY_TASK_ID}" == "2" ]]; then
  sleep 60
  bash scripts/paper_huzhang/wait_and_collect.sh --no-wait model0 model1 model2 || true
fi
