#!/bin/bash
#SBATCH --job-name=fx-paper-hz
#SBATCH --array=0-2
#SBATCH --cpus-per-task=8
#SBATCH --time=48:00:00
#SBATCH --output=results/logs/%x_%A_%a.out
#SBATCH --error=results/logs/%x_%A_%a.err

set -euo pipefail
cd "${SLURM_SUBMIT_DIR:-.}"

export FRACTUREX_ENV_QUIET=1

CASES=(model0 square model2)
CASE="${CASES[$SLURM_ARRAY_TASK_ID]}"

mkdir -p results/logs

# Auto-detect python (conda base / python3); no venv activate needed.
bash scripts/paper_huzhang/run_baseline.sh "${CASE}"
bash scripts/paper_huzhang/run_main.sh "${CASE}"

bash scripts/run_python.sh scripts/paper_huzhang/collect_paper_bundle.py \
  --root "${FRACTUREX_RESULTS_ROOT:-results}"
